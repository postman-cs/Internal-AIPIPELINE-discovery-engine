# Database — Postgres with pgvector extension
DATABASE_URL="postgresql://pipeline:pipeline@localhost:5432/ai_pipeline?schema=public"

# Session secret — REQUIRED, minimum 32 characters
# Generate with: openssl rand -base64 48
SESSION_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-48"

# OpenAI API key — required for AI agents
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Cron secret — REQUIRED for /api/cron/daily-ingest endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE-ME-generate-with-openssl-rand-hex-32"

# (Optional) Seed token — if set, POST /api/seed requires this token
# SEED_TOKEN="your-seed-token"

# (Optional) Metrics token — if set in production, GET /api/metrics requires this token
# METRICS_TOKEN="your-metrics-token"
