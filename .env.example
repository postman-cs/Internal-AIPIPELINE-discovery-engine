# Database — Postgres with pgvector extension
DATABASE_URL="postgresql://pipeline:pipeline@localhost:5432/ai_pipeline?schema=public"

# Session secret — REQUIRED, minimum 32 characters
# Generate with: openssl rand -base64 48
SESSION_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-48"

# OpenAI API key — required for AI agents
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Cron secret — REQUIRED for /api/cron/daily-ingest endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="CHANGE-ME-generate-with-openssl-rand-hex-32"

# Google OAuth — required for Gmail auto-ingest
# Get from: https://console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0 Client ID
# GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="your-client-secret"
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# (Optional) Postman API key — required for collection/environment/monitor sync
# Get from: https://go.postman.co/settings/me/api-keys
# POSTMAN_API_KEY="PMAK-your-postman-api-key-here"

# (Optional) Webhook secret — for /api/webhooks/* endpoints (ingest, newman-results)
# Generate with: openssl rand -hex 32
# WEBHOOK_SECRET="your-webhook-secret"

# (Optional) Seed token — if set, POST /api/seed requires this token
# SEED_TOKEN="your-seed-token"

# (Optional) Metrics token — if set in production, GET /api/metrics requires this token
# METRICS_TOKEN="your-metrics-token"
