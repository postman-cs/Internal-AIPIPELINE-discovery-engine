generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// Production: use PgBouncer URL with ?pgbouncer=true
datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ---------------------------------------------------------------------------
// Cascade Update Enums
// ---------------------------------------------------------------------------

enum Phase {
  DISCOVERY
  CURRENT_TOPOLOGY
  DESIRED_FUTURE_STATE
  SOLUTION_DESIGN
  INFRASTRUCTURE
  TEST_DESIGN
  CRAFT_SOLUTION
  TEST_SOLUTION
  DEPLOYMENT_PLAN
  MONITORING        // legacy — retained for DB compatibility
  ITERATION         // legacy — retained for DB compatibility
  MEETINGS
  WORKING_SESSIONS
  BUILD_LOG
}

enum ArtifactStatus {
  CLEAN
  DIRTY
  STALE
  NEEDS_REVIEW
  CLEAN_WITH_EXCEPTIONS
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ---------------------------------------------------------------------------
// Topology Enums
// ---------------------------------------------------------------------------

enum TopologyNodeType {
  SERVICE
  API
  GATEWAY
  DATABASE
  IDENTITY_PROVIDER
  CDN
  LOAD_BALANCER
  CLIENT
  EXTERNAL_SYSTEM
  QUEUE
  STORAGE
}

enum TopologyEdgeType {
  CALLS
  AUTHENTICATES_WITH
  ROUTES_THROUGH
  READS_FROM
  WRITES_TO
  DEPENDS_ON
}

// ---------------------------------------------------------------------------
// Auth & Users
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  ADMIRAL
  CSE
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  passwordHash        String
  role                UserRole             @default(CSE)
  isAdmin             Boolean              @default(false)
  googleAccessToken   String?
  googleRefreshToken  String?
  googleTokenExpiry   DateTime?
  googleEmail         String?
  jiraBaseUrl         String?
  jiraEmail           String?
  jiraApiToken        String?
  jiraDefaultProject  String?
  jiraIssueType       String?             @default("Task")
  // Gamification
  xp                  Int                  @default(0)
  xpLevel             Int                  @default(1)
  xpStreak            Int                  @default(0)
  lastXpEventAt       DateTime?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  projects            Project[]
  ingestRuns          IngestRun[]
  ingestSourceConfigs IngestSourceConfig[]
  admiralNotes        AdmiralNote[]      @relation("noteAuthor")
  cseNotes            AdmiralNote[]      @relation("noteCse")
  authoredTasks       AdmiralTask[]      @relation("taskAuthor")
  assignedTasks       AdmiralTask[]      @relation("taskAssignee")
  xpEvents            XpEvent[]
}

model XpEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  action      String
  points      Int
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AdmiralNote {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation("noteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cseUserId   String?
  cseUser     User?    @relation("noteCse", fields: [cseUserId], references: [id])
  phase       String?
  scope       String   @default("project")
  content     String
  pinned      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([authorId])
  @@index([cseUserId])
}

model AdmiralTask {
  id          String    @id @default(cuid())
  authorId    String
  author      User      @relation("taskAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  assigneeId  String
  assignee    User      @relation("taskAssignee", fields: [assigneeId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  priority    String    @default("medium")
  status      String    @default("pending")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([assigneeId])
  @@index([authorId])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Projects
// ---------------------------------------------------------------------------

model Project {
  id                   String              @id @default(cuid())
  name                 String
  primaryDomain        String?
  apiDomain            String?
  publicWorkspaceUrl   String?
  customerContactName  String?
  customerContactEmail String?
  status               String              @default("active")
  engagementStage      Int                 @default(0) // 0=Allocated, 1=Requested, 2=Approved, 3=Engaged, 4=Pitched, 5=POV, 6=Delivered, 7=Closed/Won
  completedAt          DateTime?
  closedWonAt          DateTime?
  clonedFromId         String?
  ownerUserId          String?
  owner                User?               @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  discoveryArtifacts   DiscoveryArtifact[]
  sourceDocuments      SourceDocument[]
  aiRuns               AIRun[]
  evidenceSnapshots    EvidenceSnapshot[]
  phaseArtifacts       PhaseArtifact[]
  recomputeJobs        RecomputeJob[]
  proposals            Proposal[]
  topologyNodes        TopologyNode[]
  topologyEdges        TopologyEdge[]
  topologySnapshots    TopologySnapshot[]
  notes                ProjectNote[]
  isPinned             Boolean             @default(false)

  // Gmail auto-ingest
  gmailLabelId         String?
  gmailFilterId        String?
  gmailLastSyncAt      DateTime?

  // Jira auto-track
  jiraIssueKey         String?
  jiraIssueId          String?
  jiraProjectKey       String?

  // Feature #1, #2, #3: Postman API integration
  postmanApiKey        String?             // Encrypted Postman API key
  postmanWorkspaceId   String?             // Postman workspace ID for syncing

  // Service template (customer's OpenAPI spec, Postman collection, etc.)
  serviceTemplateContent  String?          // Raw template content (YAML/JSON)
  serviceTemplateType     String?          // openapi, postman-collection, docker-compose, custom
  serviceTemplateFileName String?          // Original file name for display
  serviceTemplateNotes    String?          // CSE notes about the template

  // Repo delivery tracking
  lastRepoPushAt       DateTime?           // Last time artifacts were pushed to repo
  lastRepoPrUrl        String?             // URL of most recent delivery PR
  lastRepoPrNumber     Int?                // PR number for status polling

  // Feature #5: Git integration
  gitProvider          String?             // github, gitlab, bitbucket
  gitRepoOwner         String?
  gitRepoName          String?
  gitToken             String?             // Encrypted PAT/OAuth token
  gitBaseBranch        String?             @default("main")

  // POC Deliverables tracking
  pocDeliverablesJson  Json?               // [{id, title, description, completed, completedAt, evidenceUrl?, notes?}]

  // Shareable architecture form
  architectShareToken  String?   @unique   // UUID token for public architecture form link
  architectShareData   Json?               // Partial form data saved by CSE for pre-population

  // Feature #13: Governance
  governanceRulesJson  Json?               // Governance rules config

  // Point 35: Webhook-based evidence ingestion
  webhookSecret        String?             // Encrypted per-project webhook secret

  // Point 37: Slack integration
  slackWebhookUrl      String?             // Slack incoming webhook URL for alerts

  // Feature #14: Multi-workspace / multi-team
  workspaces           ProjectWorkspace[]

  // Feature #8: Pipeline tracking
  pipelineDeployments  PipelineDeployment[]

  // Feature #17: Newman results
  newmanTestResults    NewmanTestResult[]

  // Human Assumption Verification
  assumptions          Assumption[]

  // Blocker System
  blockers             Blocker[]

  // Wide Adoption Accelerator
  admiralNotes         AdmiralNote[]
  admiralTasks         AdmiralTask[]

  // Gamification
  xpEvents             XpEvent[]
}

// ---------------------------------------------------------------------------
// Ingest Infrastructure (existing)
// ---------------------------------------------------------------------------

model IngestSourceConfig {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  source            String
  enabled           Boolean  @default(true)
  configJson        String?
  lastSyncAt        DateTime?
  lastSyncStatus    String?
  lastSyncItemCount Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, source])
  @@index([userId])
}

model IngestRun {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt     DateTime    @default(now())
  finishedAt    DateTime?
  status        String      @default("QUEUED")
  trigger       String      @default("MANUAL")
  sourcesFilter String?
  summary       String?
  countsJson    String?
  items         IngestItem[]

  @@index([userId])
  @@index([startedAt])
}

model IngestItem {
  id           String    @id @default(cuid())
  ingestRunId  String
  ingestRun    IngestRun @relation(fields: [ingestRunId], references: [id], onDelete: Cascade)
  source       String
  externalId   String?
  title        String
  timestamp    DateTime  @default(now())
  url          String?
  rawText      String?
  metadataJson String?
  consumedAt   DateTime?

  @@index([ingestRunId])
  @@index([source])
  @@index([consumedAt])
}

// ---------------------------------------------------------------------------
// AI Document Pipeline (new)
// ---------------------------------------------------------------------------

model SourceDocument {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceType      String          // KEPLER, DNS, HEADERS, GITHUB, MANUAL, SLACK, GMAIL, OPENAPI, etc.
  externalId      String?         // External source dedup key (e.g. email ID, file hash)
  contentHash     String?         // SHA-256 of rawText for idempotent ingestion
  title           String?
  rawText         String
  metadataJson    Json?
  lastVerifiedAt  DateTime?       // Point 41: when this doc was last re-verified
  freshnessScore  Int?            // Point 41: 0-100 freshness score
  createdAt       DateTime        @default(now())
  chunks          DocumentChunk[]

  @@unique([projectId, contentHash])
  @@index([projectId, externalId])
  @@index([projectId, sourceType])
}

model DocumentChunk {
  id            String                      @id @default(cuid())
  documentId    String
  document      SourceDocument              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  projectId     String
  content       String
  embedding     Unsupported("vector(3072)")
  tokenCount    Int?
  evidenceLabel String                      // EVIDENCE-1, EVIDENCE-2, ...
  createdAt     DateTime                    @default(now())

  @@index([projectId])
  @@index([projectId, evidenceLabel])
}

model AIRun {
  id         String   @id @default(cuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  agentType  String   // ReconSynthesizer, SignalClassifier, MaturityScorer, HypothesisGenerator, BriefGenerator, etc.
  model      String
  promptHash String
  snapshotId String?  // EvidenceSnapshot used for this run (observability)
  inputJson  Json
  outputJson Json?
  tokenUsage Json?
  durationMs Int?
  messagesJson    Json?    // Point 4: multi-turn message history
  citationAccuracy Float?  // Point 5: ratio of valid citations to total
  zodParseAttempts Int?    // Point 2: how many parse strategies were tried
  status     String   // RUNNING, SUCCESS, FAILED
  createdAt  DateTime @default(now())

  @@index([projectId])
  @@index([agentType])
  @@index([createdAt])
  @@index([projectId, agentType])
}

// ---------------------------------------------------------------------------
// Discovery Artifacts (existing — enhanced with AI citations)
// ---------------------------------------------------------------------------

model DiscoveryArtifact {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   Int     @default(1)

  // Kepler
  keplerPaste String?

  // Outside-In Terrain Map
  dnsFindings              String?
  headerFindings           String?
  publicFootprint          String?
  authForensics            String?
  cloudGatewaySignals      String?
  developerFrictionSignals String?
  evidenceLinksJson        String?

  // Company Snapshot
  industry          String?
  engineeringSize   String?
  publicApiPresence String?

  // Technical Landscape
  technicalLandscapeJson String?

  // Maturity
  maturityLevel         Int?
  maturityJustification String?
  confidenceJson        String?

  // Hypothesis + Approach
  hypothesis          String?
  recommendedApproach String?
  conversationAngle   String?

  // Stakeholders
  stakeholderTargetsJson String?
  firstMeetingAgendaJson String?

  // Generated Brief
  generatedBriefMarkdown String?
  generatedBriefJson     String?

  // AI provenance (new)
  aiGenerated        Boolean  @default(false)
  aiRunIds           Json?    // Array of AIRun IDs that produced this artifact
  evidenceCitations  Json?    // Array of { evidenceLabel, chunkId, sourceType, usedInSection }

  createdAt DateTime @default(now())

  @@unique([projectId, version])
}

// ---------------------------------------------------------------------------
// Cascade Update System
// ---------------------------------------------------------------------------

model EvidenceSnapshot {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chunkIdsJson Json     // Array of DocumentChunk IDs in this snapshot
  countsJson   Json?    // { bySource: { KEPLER: 5, DNS: 3, ... }, total: 8 }
  hash         String   // SHA-256 of sorted chunk IDs for reproducibility
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model PhaseArtifact {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           Phase
  version         Int
  status          ArtifactStatus @default(DIRTY)
  snapshotId      String?        // EvidenceSnapshot this was computed against
  derivedFromJson Json?          // { upstreamRefs: [{ phase, version }], snapshotHash }
  contentJson     Json           // Structured phase output (Discovery brief JSON, etc.)
  contentMarkdown String?        // Rendered markdown for human consumption
  lastComputedAt  DateTime?
  ignoredSnapshotIds Json?       // Array of snapshot IDs user explicitly rejected
  createdAt       DateTime       @default(now())

  @@unique([projectId, phase, version])
  @@index([projectId, phase])
  @@index([projectId, phase, status])
}

model RecomputeJob {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggeredBy String          // INGEST, MANUAL
  snapshotId  String?         // Snapshot that triggered this job
  status      String          @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  startedAt   DateTime        @default(now())
  finishedAt  DateTime?
  tasks       RecomputeTask[]

  @@index([projectId])
}

model RecomputeTask {
  id            String       @id @default(cuid())
  jobId         String
  job           RecomputeJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  phase         Phase
  status        String       @default("PENDING") // PENDING, RUNNING, COMPLETED, SKIPPED, FAILED
  inputRefsJson Json         // { upstreamVersions: { DISCOVERY: 3 }, snapshotId: "..." }
  proposalId    String?      // Created proposal, if any
  message       String?      // Status message / error
  startedAt     DateTime?
  finishedAt    DateTime?

  @@index([jobId, status])
}

model Proposal {
  id                  String         @id @default(cuid())
  projectId           String
  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase               Phase
  snapshotId          String         // Snapshot used for this recompute
  baseArtifactVersion Int            // Version of the artifact this patches
  patchJson           Json           // Array of patch operations
  proposedJson        Json           // Full proposed artifact content
  proposedMarkdown    String?        // Rendered proposed markdown
  diffSummary         String?        // Human-readable summary of changes
  status              ProposalStatus @default(PENDING)
  aiRunIds            Json?          // Array of AIRun IDs used
  createdAt           DateTime       @default(now())
  resolvedAt          DateTime?

  @@index([projectId, phase])
  @@index([projectId, status])
}

// ---------------------------------------------------------------------------
// Topology Graph Models
// ---------------------------------------------------------------------------

model TopologyNode {
  id           String           @id @default(cuid())
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type         TopologyNodeType
  name         String
  metadataJson Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([projectId])
}

model TopologyEdge {
  id           String           @id @default(cuid())
  projectId    String
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromNodeId   String
  toNodeId     String
  type         TopologyEdgeType
  metadataJson Json?
  createdAt    DateTime         @default(now())

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Project Notes (scratchpad)
// ---------------------------------------------------------------------------

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

model TopologySnapshot {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshotId   String   // link to EvidenceSnapshot
  nodeIdsJson  Json
  edgeIdsJson  Json
  createdAt    DateTime @default(now())

  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Feature #14: Multi-Workspace / Multi-Team
// ---------------------------------------------------------------------------

model ProjectWorkspace {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceName   String
  workspaceId     String?  // Postman workspace ID
  apiKey          String?  // Encrypted API key for this workspace
  team            String?  // Team name/label
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId, workspaceName])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Feature #8: Pipeline Adoption Tracker
// ---------------------------------------------------------------------------

model PipelineDeployment {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  platform      String    // github_actions, gitlab_ci, jenkins, etc.
  platformLabel String
  repoUrl       String?
  pipelineRef   String?   // PR number, MR IID, etc.
  filename      String?
  branchName    String?
  prUrl         String?
  lastStatus    String    @default("pending") // pending, active, passing, failing, unknown
  lastRunAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([projectId])
  @@index([platform])
}

// ---------------------------------------------------------------------------
// Feature #17: Newman Test Results Ingestion
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Human Assumption Verification
// ---------------------------------------------------------------------------

enum AssumptionStatus {
  PENDING          // Awaiting human review
  VERIFIED         // Human confirmed as correct
  CORRECTED        // Human provided a correction
  REJECTED         // Human said this is wrong
  AUTO_VERIFIED    // Auto-verified from prior phase evidence
}

model Assumption {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           Phase            // Which phase surfaced this assumption
  category        String           // cloud_provider, ci_cd_platform, auth_pattern, api_architecture, etc.
  claim           String           // The assumption text (what the AI believes)
  reasoning       String?          // Why the AI believes this
  confidence      String           @default("Medium") // High, Medium, Low
  evidenceIds     Json?            // Evidence IDs supporting this assumption
  impact          String?          // What goes wrong if this assumption is incorrect
  status          AssumptionStatus @default(PENDING)
  humanResponse   String?          // Human's correction text (if CORRECTED)
  verifiedBy      String?          // userId of the verifier
  verifiedAt      DateTime?
  blocksPhases    Json?            // Array of Phase names that depend on this assumption
  recomputeJobId  String?          // Links to the recompute job that generated this
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([projectId, phase, category])
  @@index([projectId, status])
  @@index([recomputeJobId])
}

model NewmanTestResult {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  collectionName  String?
  environmentName String?
  totalRequests   Int      @default(0)
  totalAssertions Int      @default(0)
  passedAssertions Int     @default(0)
  failedAssertions Int     @default(0)
  totalDuration   Int      @default(0) // ms
  status          String   @default("pass") // pass, fail, error
  resultJson      Json?    // Full structured results
  source          String   @default("webhook") // webhook, dry-run, ci
  createdAt       DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Blocker System: Map → Missile → Nuke
// ---------------------------------------------------------------------------

enum BlockerSeverity {
  LOW           // Inconvenient but workable
  MEDIUM        // Slows progress, needs attention
  HIGH          // Blocks a critical path
  CRITICAL      // Full stop — nothing moves until this is resolved
}

enum BlockerStatus {
  IDENTIFIED    // Just discovered
  MAPPED        // Fully analyzed — stakeholders, impact, root cause known
  MISSILE_DESIGNED  // Targeted intervention plan is ready
  MISSILE_FIRED     // Intervention is in progress
  NUKE_ARMED        // Nuclear option has been designed
  NUKE_LAUNCHED     // Nuclear option is in progress
  NEUTRALIZED       // Blocker has been eliminated
  ACCEPTED          // Blocker is permanent — workaround adopted
  DORMANT           // Blocker exists but isn't currently active
}

enum BlockerDomain {
  TECHNICAL         // Can't install Newman, CI/CD doesn't support X, etc.
  ORGANIZATIONAL    // Security team won't approve, no budget, wrong team owns it
  POLITICAL         // VP prefers competitor, not-invented-here, turf war
  PROCESS           // Change board meets quarterly, compliance needs 6-month eval
  KNOWLEDGE         // Team doesn't understand value, no one knows how
  SECURITY          // Compliance blocks, data residency, audit requirements
  LICENSING         // License limitations, procurement delays
  CULTURAL          // Resistance to change, "we've always done it this way"
}

model Blocker {
  id                String          @id @default(cuid())
  projectId         String
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // --- Mapping ---
  title             String          // Short name: "Security team won't approve Newman in CI"
  description       String          // Full description of the blocker
  domain            BlockerDomain   // What kind of blocker this is
  severity          BlockerSeverity @default(MEDIUM)
  status            BlockerStatus   @default(IDENTIFIED)
  
  // What it blocks
  blockedPhases     Json?           // Array of Phase names this blocker affects
  blockedCapabilities Json?         // What features/capabilities are blocked
  
  // Root cause analysis
  rootCause         String?         // Why does this blocker exist?
  rootCauseCategory String?         // technical_limitation, org_policy, person, budget, process, unknown
  
  // Stakeholder mapping
  blockerOwner      String?         // Who controls this blocker? (person/team/role)
  decisionMaker     String?         // Who can unblock this? (different from owner)
  allies            Json?           // People/teams who want this blocker removed
  resistors         Json?           // People/teams who benefit from this blocker existing
  
  // Impact assessment
  impactScore       Int             @default(0) // 1-100 composite score
  revenueImpact     String?         // Impact on deal/revenue if not resolved
  timelineImpact    String?         // How much this delays the engagement
  cascadeImpact     String?         // What downstream work is blocked
  
  // Context from AI
  surfacedByPhase   String?         // Which pipeline phase detected this
  surfacedByAgent   String?         // Which AI agent flagged it
  evidenceIds       Json?           // Evidence supporting this blocker
  assumptionIds     Json?           // Related assumption IDs
  
  // Human notes
  notes             String?         // Free-form notes from the SE
  
  // Resolution
  resolvedAt        DateTime?
  resolvedBy        String?
  resolutionNotes   String?
  
  // Relations
  missiles          BlockerMissile[]
  nukes             BlockerNuke[]
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([projectId])
  @@index([projectId, status])
  @@index([severity])
}

/// A targeted, surgical intervention designed to neutralize a specific blocker.
/// Like a precision missile: focused, calculated, with a specific target and payload.
model BlockerMissile {
  id                String          @id @default(cuid())
  blockerId         String
  blocker           Blocker         @relation(fields: [blockerId], references: [id], onDelete: Cascade)
  
  // --- Design ---
  name              String          // "Executive ROI Presentation", "Newman Sandbox Demo"
  strategy          String          // The approach: what this missile does
  targetAudience    String?         // Who this missile is aimed at
  
  // Payload: the actual content/actions
  talkingPoints     Json?           // Key arguments / value propositions
  evidence          Json?           // Data points, case studies, proof points
  actionSteps       Json?           // Ordered list of steps to execute
  deliverables      Json?           // What to produce: deck, demo, POC, doc, etc.
  
  // Timing & effort
  estimatedEffort   String?         // "2 hours", "1 day", "1 week"
  deadline          DateTime?       // When this needs to be fired by
  
  // Success criteria
  successCriteria   String?         // How do we know it worked?
  fallbackPlan      String?         // If this missile misses, what next?
  
  // Execution
  status            String          @default("designed") // designed, in_progress, fired, hit, missed
  firedAt           DateTime?
  resultNotes       String?         // What happened when we fired it
  
  // AI-assisted design
  aiGenerated       Boolean         @default(false)
  aiRunId           String?         // If AI helped design this
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([blockerId])
}

/// The nuclear option. When surgical strikes fail, this is the comprehensive
/// strategy to obliterate the blocker through overwhelming force — executive
/// escalation, org restructuring, complete re-architecture, or finding an
/// entirely different path that makes the blocker irrelevant.
model BlockerNuke {
  id                String          @id @default(cuid())
  blockerId         String
  blocker           Blocker         @relation(fields: [blockerId], references: [id], onDelete: Cascade)
  
  // --- Strategy ---
  name              String          // "Executive Air Cover", "Complete Re-Architecture"
  rationale         String          // Why the nuclear option is necessary
  strategy          String          // The comprehensive obliteration plan
  
  // Escalation path
  escalationChain   Json?           // Ordered list of people/roles to escalate through
  executiveSponsor  String?         // Who at the highest level backs this
  
  // Collateral assessment
  collateralDamage  Json?           // What else gets affected (relationships, timeline, etc.)
  riskAssessment    String?         // What's the risk of launching this nuke
  pointOfNoReturn   String?         // At what point can we not undo this
  
  // Comprehensive action plan
  phases            Json?           // Multi-phase execution plan
  resources         Json?           // People, budget, tools needed
  timeline          String?         // Expected duration
  
  // Alternative path (bypass blocker entirely)
  bypassStrategy    String?         // How to make the blocker irrelevant
  bypassTradeoffs   String?         // What we lose by going around it
  
  // Success / failure
  successCriteria   String?
  failureContingency String?        // If even the nuke doesn't work, what then?
  
  // Execution
  status            String          @default("designed") // designed, armed, launched, detonated, failed
  armedAt           DateTime?
  launchedAt        DateTime?
  resultNotes       String?
  
  // AI-assisted design
  aiGenerated       Boolean         @default(false)
  aiRunId           String?
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([blockerId])
}

// ---------------------------------------------------------------------------
// Upgrade Plan v2: New Models
// ---------------------------------------------------------------------------

// Point 2: Dynamic model routing quality scores
model ModelQualityScore {
  id                String   @id @default(cuid())
  agentType         String
  modelId           String
  avgLatencyMs      Float    @default(0)
  avgTokenCost      Float    @default(0)
  successRate       Float    @default(1)
  avgZodParseAttempts Float  @default(1)
  sampleCount       Int      @default(0)
  lastUpdated       DateTime @default(now())

  @@unique([agentType, modelId])
  @@index([agentType])
}

// Point 3: Agent evaluation results
model AgentEvalResult {
  id          String   @id @default(cuid())
  agentType   String
  modelId     String
  testCaseId  String
  passed      Boolean
  assertions  Json?
  inputJson   Json?
  outputJson  Json?
  durationMs  Int?
  errorMsg    String?
  createdAt   DateTime @default(now())

  @@index([agentType])
  @@index([createdAt])
}

// Point 13: Audit log for sensitive operations
enum AuditAction {
  LOGIN
  LOGOUT
  PROJECT_CREATE
  PROJECT_DELETE
  PROPOSAL_ACCEPT
  PROPOSAL_REJECT
  SECRET_ACCESS
  ROLE_CHANGE
  EXPORT
  SEED
  BLOCKER_ESCALATE
  ASSUMPTION_VERIFY
  CASCADE_TRIGGER
  REPO_PUSH
  SETTINGS_CHANGE
}

model AuditLog {
  id           String      @id @default(cuid())
  userId       String
  action       AuditAction
  targetId     String?
  targetType   String?
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([targetId])
}

// Point 16: Secrets rotation tracking
model SecretRotation {
  id          String   @id @default(cuid())
  projectId   String
  secretType  String
  lastRotatedAt DateTime @default(now())
  expiresAt   DateTime?
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@unique([projectId, secretType])
  @@index([expiresAt])
}

// Point 23: Notification center
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  linkUrl   String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Point 49: Multi-tenant workspace isolation
model Workspace {
  id        String               @id @default(cuid())
  name      String
  slug      String               @unique
  ownerId   String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   WorkspaceMembership[]

  @@index([ownerId])
}

model WorkspaceMembership {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  role        String    @default("member")
  joinedAt    DateTime  @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}
